{
  "name": "cloudcli-plugin-workspace-scheduled-prompts",
  "version": "0.1.0",
  "private": true,
  "description": "CloudCLI plugin for workspace-scoped scheduled prompts.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --format=esm --platform=browser --outfile=dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.25.11",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
